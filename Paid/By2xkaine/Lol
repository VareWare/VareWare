    NotifText.Font=Enum.Font.GothamBold; NotifText.TextColor3=C.WHITE; NotifText.Text=name.."  −"..damage; NotifText.TextSize=14
    TweenService:Create(Notif,TweenInfo.new(0.2),{Position=UDim2.new(1,0,0,0)}):Play()
    task.wait(2.5); TweenService:Create(Notif,TweenInfo.new(1,0,0,0),{BackgroundTransparency=1}):Play()
    task.wait(0.4); Notif:Destroy()
end

