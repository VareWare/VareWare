local function HasLineOfSight(fromPos, toPart)
    if not fromPos or not toPart then return false end
    local offset = Vector3.new(0, 1, 0)
    local dir = toPart.Position - (fromPos + offset)
    local res = Workspace:Raycast(fromPos + offset, dir, RaycastParams)
    return not res or res.Instance:IsDescendantOf(toPart.Parent)
end

local function CanAim()
    if not Humanoid then return false end
    return Humanoid.Health > 13
end

local function IsRagdolled(hum)
    if not hum or not hum.Parent then return true end
    local char = hum.Parent
    return hum:GetState() == Enum.HumanoidStateType.Ragdoll
        or char:FindFirstChild("IsRagdoll") and char.IsRagdoll.Value == true
end

local function IsValidTarget(char)
    local hum = char and char:FindFirstChild("Humanoid")
    if not hum then return false end
    if hum.Health <= 1 then return false end
    if hum.Health <= 13 then return false end
    return not IsRagdolled(hum)
end

