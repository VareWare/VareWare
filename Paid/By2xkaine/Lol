local function MakeSkeleton(char)
    local skel = {}
    local connections = {{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},{"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},{"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"}}
    for _,pair in pairs(connections) do
        local l = Drawing.new("Line")
        l.Color = C.WHITE; l.Thickness = 1.5; l.Transparency = 1; l.Visible = false
        table.insert(skel, {Line=l, A=pair[1], B=pair[2]})
    end
    return skel
end

local function RemoveEnemy(uid)
    local d = _G.Enemies[uid]; if not d then return end
    if d.Glow then d.Glow:Destroy() end
    if d.Tag then d.Tag:Destroy() end
    if d.Skeleton then for _,v in pairs(d.Skeleton) do v.Line:Remove() end end
    if d.Row then d.Row:Destroy() end
    _G.Enemies[uid] = nil
    LastKnownHealth[uid] = nil
    EnemyList.CanvasSize = UDim2.new(0,0,0,Layout.AbsoluteContentSize.Y)
    if CurrentTarget and d.Player and CurrentTarget.Parent == d.Player.Character then CurrentTarget = nil end
end

