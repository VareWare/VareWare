local function AddToggleSlider(name, posY, setting, toggleSetting, minVal, maxVal, default, parent)
    parent = parent or TabAim
    local c = Instance.new("Frame", parent); c.Size=UDim2.new(1,0,0,55); c.Position=UDim2.new(0,0,posY,0); c.BackgroundTransparency=1
    local tb = Instance.new("TextButton", c); tb.Size=UDim2.new(0,32,0,32); tb.Position=UDim2.new(0,0,0.5,-16)
    tb.BackgroundColor3=_G.Settings[toggleSetting] and C.WHITE or C.GREY
    tb.Text=_G.Settings[toggleSetting] and "✓" or ""
    tb.Font=Enum.Font.GothamBold; tb.TextColor3=_G.Settings[toggleSetting] and C.BLACK or C.WHITE; tb.TextSize=18
    Instance.new("UICorner",tb).CornerRadius=UDim.new(0.15,0)
    local lbl = Instance.new("TextLabel", c); lbl.Size=UDim2.new(0.32,0,1,0); lbl.Position=UDim2.new(0.06,0,0,0)
    lbl.BackgroundTransparency=1; lbl.Font=Enum.Font.GothamSemibold; lbl.TextColor3=C.WHITE; lbl.TextSize=15; lbl.Text=name..": "..default
    local bg = Instance.new("Frame", c); bg.Size=UDim2.new(0.58,0,0,12); bg.Position=UDim2.new(0.38,0,0.4,0); bg.BackgroundColor3=C.GREY
    Instance.new("UICorner",bg).CornerRadius=UDim.new(1,0)
    local fill = Instance.new("Frame",bg); fill.Size=UDim2.new((default-minVal)/(maxVal-minVal),0,1,0); fill.BackgroundColor3=C.WHITE
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)

    tb.MouseButton1Click:Connect(function()
        PlaySound(SOUND_BTN)
        _G.Settings[toggleSetting] = not _G.Settings[toggleSetting]
        tb.Text = _G.Settings[toggleSetting] and "✓" or ""
        tb.BackgroundColor3 = _G.Settings[toggleSetting] and C.WHITE or C.GREY
        tb.TextColor3 = _G.Settings[toggleSetting] and C.BLACK or C.WHITE
        bg.Visible = _G.Settings[toggleSetting] -- ✅ SLIDER HIDES WHEN TOGGLED OFF
    end)

    local draggingSlider=false
    local function UpdateSlider(input)
        if not _G.Settings[toggleSetting] then return end -- ✅ SLIDER DOES NOT WORK WHEN OFF
        local relX=math.clamp((input.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
        local val=math.floor(minVal+relX*(maxVal-minVal))
        _G.Settings[setting]=val; lbl.Text=name..": "..val; fill.Size=UDim2.new(relX,0,1,0)
        if setting=="WalkSpeed" and Humanoid then Humanoid.WalkSpeed=val end
        if setting=="JumpPower" and Humanoid then Humanoid.JumpPower=val end
    end
    bg.InputBegan:Connect(function(input) if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then PlaySound(SOUND_BTN); draggingSlider=true; UpdateSlider(input) end end)
    UserInputService.InputChanged:Connect(function(input) if draggingSlider and _G.Settings[toggleSetting] and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType.Touch) then UpdateSlider(input) end end)
    UserInputService.InputEnded:Connect(function() draggingSlider=false end)
end

