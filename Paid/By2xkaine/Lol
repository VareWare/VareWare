-- FIXED WALL CHECK
local function HasLineOfSight(fromPos, targetPart)
    if not fromPos or not targetPart or not targetPart.Parent then return false end
    local char = targetPart.Parent
    if not char:FindFirstChildOfClass("Humanoid") then return false end

    local CheckParts = {"Head", "UpperTorso", "LowerTorso", "LeftUpperArm", "RightUpperArm", "LeftUpperLeg", "RightUpperLeg"}
    local function IsPartVisible(partName)
        local part = char:FindFirstChild(partName)
        if not part then return false end
        local dir = part.Position - (fromPos + Vector3.new(0, 1.6, 0))
        local result = Workspace:Raycast(fromPos + Vector3.new(0, 1.6, 0), dir, RaycastParams)
        if not result then return true end
        local hit = result.Instance

        if hit:IsDescendantOf(char) then return true end
        if hit.Transparency >= 0.4 then return true end
        if hit.Size.Magnitude < 2 then return true end
        if hit:GetAttribute("Projectile") or hit:GetAttribute("Weapon") then return true end
        return false
    end
    for _,name in pairs(CheckParts) do if IsPartVisible(name) then return true end end
    return false
end

local function CanAim() return Humanoid and Humanoid.Health > 13 end
local function IsRagdolled(hum)
    if not hum or not hum.Parent then return true end
    local char = hum.Parent
    return hum:GetState() == Enum.HumanoidStateType.Ragdoll or (char:FindFirstChild("IsRagdoll") and char.IsRagdoll.Value)
end
local function IsValidTarget(char)
    local hum = char and char:FindFirstChild("Humanoid")
    return hum and hum.Health > 13 and not IsRagdolled(hum)
end

local function GetBestTarget()
    if not CanAim() or not _G.Settings.AimlockV2 then CurrentTarget=nil return nil end
    local best, bestDist = nil, math.huge
    local camDir = Camera.CFrame.LookVector

    for _,d in pairs(_G.Enemies) do
        local plr = d.Player; if not plr then continue end
        local char = plr.Character
        local aimPart = char and char:FindFirstChild(_G.Settings.AimPart)
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not IsValidTarget(char) or not aimPart or not hrp then continue end
        if not HasLineOfSight(HumanoidRootPart.Position, aimPart) then continue end

        local toTarget = (aimPart.Position - Camera.CFrame.Position).Unit
        local angleValid = _G.Settings.Aim360 or camDir:Dot(toTarget) > 0.2

        if angleValid then
            local dist = (Camera.CFrame.Position - aimPart.Position).Magnitude
            if dist < bestDist then bestDist = dist; best = aimPart end
        end
    end
    CurrentTarget = best; return best
end

local function TriggerBot()
    if not _G.Settings.AutoAir then return end
    if not CurrentTarget or os.clock() - LastTriggerClick < _G.Settings.TriggerDelay then return end
    local char = CurrentTarget.Parent; if not char then return end
    local hum = char:FindFirstChild("Humanoid"); if not hum or hum.Health <= 0 then return end
    local inAir = hum.FloorMaterial == Enum.Material.Air
        or hum:GetState() == Enum.HumanoidStateType.Jumping
        or hum:GetState() == Enum.HumanoidStateType.Freefall
    if not inAir then return end
    local tool = Character and Character:FindFirstChildOfClass("Tool")
    if tool then tool:Activate(); LastTriggerClick = os.clock() end
end

local function CaptureSkeleton(character)
    local Data = {Parts = {}, Joints = {}}
    for _,Desc in pairs(character:GetDescendants()) do
        if Desc:IsA("BasePart") then
            Data.Parts[Desc.Name] = {CFrame = Desc.CFrame, Size = Desc.Size, Transparency = Desc.Transparency}
        elseif Desc:IsA("Motor6D") then
            Data.Joints[Desc.Name] = {C0 = Desc.C0, C1 = Desc.C1}
        end
    end
    return Data
end
local function FreezeSkeleton(character, SavedData)
    if not character or not SavedData then return end
    for Name,Pos in pairs(SavedData.Parts) do
        local Part = character:FindFirstChild(Name)
        if Part and Part:IsA("BasePart") then Part.CFrame = Pos.CFrame end
    end
    for Name,Data in pairs(SavedData.Joints) do
        local Motor = character:FindFirstChild(Name, true)
        if Motor and Motor:IsA("Motor6D") then Motor.C0 = Data.C0; Motor.C1 = Data.C1 end
    end
end

local function MakeRotatingCrosshair()
    local Crosshair = {Lines = {}, Label = nil}
    for i=1,4 do local l = Drawing.new("Line"); l.Color=C.WHITE; l.Thickness=2; l.Transparency=1; l.Visible=false; table.insert(Crosshair.Lines,l) end
    Crosshair.Label = Drawing.new("Text"); Crosshair.Label.Center=true; Crosshair.Label.Outline=true; Crosshair.Label.Color=C.WHITE; Crosshair.Label.Font=2; Crosshair.Label.Size=14; Crosshair.Label.Visible=false
    Crosshair.Update = function(self)
        if not _G.Settings.TargetIndicator or not CurrentTarget then for _,l in ipairs(self.Lines) do l.Visible=false end; self.Label.Visible=false; return end
        local pos,vis = Camera:WorldToViewportPoint(CurrentTarget.Position)
        if not vis then for _,l in ipairs(self.Lines) do l.Visible=false end; self.Label.Visible=false; return end
        local size=12; local rot=os.clock()*3
        local pts={Vector2.new(pos.X+math.cos(rot)*size,pos.Y+math.sin(rot)*size),Vector2.new(pos.X+math.cos(rot+1.57)*size,pos.Y+math.sin(rot+1.57)*size),Vector2.new(pos.X+math.cos(rot+3.14)*size,pos.Y+math.sin(rot+3.14)*size),Vector2.new(pos.X+math.cos(rot+4.71)*size,pos.Y+math.sin(rot+4.71)*size)}
        for i=1,4 do local l=self.Lines[i]; l.From=pts[i]; l.To=pts[i%4+1]; l.Visible=true end
        self.Label.Position=Vector2.new(pos.X,pos.Y-25); self.Label.Text="AIM: "..CurrentTarget.Name:upper(); self.Label.Visible=true
    end
    RotateIndicator = Crosshair
end
