local function GetBestTarget()
    if not CanAim() or (not _G.Settings.Aimlock and not _G.Settings.AimlockV2) then
        CurrentTarget = nil; return nil
    end
    if CurrentTarget then
        local targetChar = CurrentTarget.Parent
        if not IsValidTarget(targetChar) then CurrentTarget = nil
        else
            local requiredPart = targetChar:FindFirstChild(_G.Settings.AimPart)
            if requiredPart and CurrentTarget == requiredPart and HasLineOfSight(HumanoidRootPart.Position, CurrentTarget) then
                return CurrentTarget
            end
            CurrentTarget = nil
        end
    end
    local best, bestDist = nil, math.huge
    for _, data in pairs(_G.Enemies) do
        local plr = data.Player; if not plr then continue end
        local char = plr.Character
        local aimPart = char and char:FindFirstChild(_G.Settings.AimPart)
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if IsValidTarget(char) and aimPart and hrp and HasLineOfSight(HumanoidRootPart.Position, aimPart) then
            local dist = (Camera.CFrame.Position - aimPart.Position).Magnitude
            if dist < bestDist then bestDist = dist; best = aimPart end
        end
    end
    CurrentTarget = best; return best
end

local function AutoAirCheck(target)
    if not _G.Settings.AutoAirTrigger or not target then return end
    if not CanAim() then return end
    if os.clock() - LastShot < AUTO_SHOOT_DELAY then return end
    local LocalTool = Character:FindFirstChildOfClass("Tool")
    if not LocalTool then return end
    local TargetChar = target.Parent
    local TargetHum = TargetChar:FindFirstChild("Humanoid")
    if not TargetHum or not IsValidTarget(TargetChar) then return end
    local IsInAir = TargetHum.FloorMaterial == Enum.Material.Air
        or TargetHum:GetState() == Enum.HumanoidStateType.Jumping
        or TargetHum:GetState() == Enum.HumanoidStateType.Freefall
    if not IsInAir then return end
    task.spawn(function()
        UserInputService:InputBegan({UserInputType = Enum.UserInputType.MouseButton1, GameProcessedEvent = false}, game)
        task.wait(0.03)
        UserInputService:InputEnded({UserInputType = Enum.UserInputType.MouseButton1, GameProcessedEvent = false}, game)
        LastShot = os.clock()
    end)
end

RunService.RenderStepped:Connect(function()
    if RotateIndicator then RotateIndicator:Update(CurrentTarget and CurrentTarget.Position or nil) end
    if ViewTarget and ViewTarget.Character and ViewTarget.Character:FindFirstChild("HumanoidRootPart") then
        local Pos = ViewTarget.Character.HumanoidRootPart.Position
        Camera.CFrame = CFrame.new(Pos + Vector3.new(8,4,0), Pos)
    end
    if not Character or not HumanoidRootPart then CurrentTarget=nil return end
    local target = GetBestTarget()
    if _G.Settings.AutoZoomEnabled then Camera.FieldOfView = target and _G.Settings.ZoomFOV or _G.Settings.NormalFOV end
    if target then
        AutoAirCheck(target)
        local aimPos = target.Position
        if _G.Settings.Aimlock then
            local camPos = Camera.CFrame.Position
            local smooth = _G.Settings.AimSpeed / 100
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(camPos, aimPos), smooth)
        end
        if _G.Settings.AimlockV2 then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, aimPos)
        end
    end
    for uid,d in pairs(_G.Enemies) do
        local p=d.Player; if not p then RemoveEnemy(uid) continue end
        local c=p.Character; local hum=c and c:FindFirstChild("Humanoid")
        local hrp=c and c:FindFirstChild("HumanoidRootPart")
        if c and IsValidTarget(c) and hrp then
            d.Glow.Enabled = _G.Settings.ShowNameDist
            d.Tag.Enabled = _G.Settings.ShowNameDist
            if _G.Settings.ShowNameDist then
                d.Glow.Adornee=c; d.Tag.Adornee=hrp
                d.TName.Text=p.DisplayName
                d.TDist.Text=math.floor((HumanoidRootPart.Position-hrp.Position).Magnitude).." studs"
            end
            if d.Skeleton then
                for _,v in pairs(d.Skeleton) do
                    local a = c:FindFirstChild(v.A)
                    local b = c:FindFirstChild(v.B)
                    if a and b then
                        local posA, visA = Camera:WorldToViewportPoint(a.Position)
                        local posB, visB = Camera:WorldToViewportPoint(b.Position)
                        v.Line.Visible = _G.Settings.ShowSkeleton and visA and visB
                        if v.Line.Visible then v.Line.From = Vector2.new(posA.X,posA.Y); v.Line.To = Vector2.new(posB.X,posB.Y) end
                    else v.Line.Visible = false end
                end
            end
        else
            d.Glow.Enabled=false; d.Tag.Enabled=false
            if d.Skeleton then for _,v in pairs(d.Skeleton) do v.Line.Visible=false end end
        end
    end
end)

