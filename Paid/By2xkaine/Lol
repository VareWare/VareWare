local function ShowHitNotif(name, damage)
    local now=os.clock()
    if damage<MIN_NOTIFY_DAMAGE or now-LastNotifTime<NOTIF_COOLDOWN then return end
    LastNotifTime=now
    PlaySound(SOUND_NOTIF,0.3)
    local Notif=Instance.new("Frame",NotifContainer)
    Notif.Size=UDim2.new(1,0,0,40); Notif.Position=UDim2.new(1,20,0,0)
