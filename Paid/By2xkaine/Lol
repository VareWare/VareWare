local function AddSlider(name,posY,setting,default)
    local c=Instance.new("Frame",TabAim); c.Size=UDim2.new(1,0,0,55); c.Position=UDim2.new(0,0,posY,0); c.BackgroundTransparency=1
    local lbl=Instance.new("TextLabel",c); lbl.Size=UDim2.new(0.4,0,1,0); lbl.BackgroundTransparency=1
    lbl.Font=Enum.Font.GothamSemibold; lbl.TextColor3=C.WHITE; lbl.TextSize=15; lbl.Text = name..": "..default
    local bg=Instance.new("Frame",c); bg.Size=UDim2.new(0.5,0,0,12); bg.Position=UDim2.new(0.45,0,0.4,0); bg.BackgroundColor3=C.GREY; Instance.new("UICorner",bg).CornerRadius=UDim.new(1,0)
    local fill=Instance.new("Frame",bg); fill.Size=UDim2.new(default/100,0,1,0); fill.BackgroundColor3=C.WHITE; Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    local draggingSlider = false
    local function UpdateSlider(input)
        local relX = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = math.floor(relX * 100)
        _G.Settings[setting] = val; lbl.Text = name..": "..val; fill.Size = UDim2.new(relX, 0, 1, 0)
    end
    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            PlaySound(SOUND_BTN); draggingSlider = true; UpdateSlider(input)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType.Touch) then UpdateSlider(input) end
    end)
    UserInputService.InputEnded:Connect(function(input) draggingSlider = false end)
end

