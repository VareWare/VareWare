local function MakeRotatingIndicator()
    local Indicator = {Lines = {}}
    for i=1,4 do
        local Line = Drawing.new("Line")
        Line.Color = C.WHITE; Line.Thickness = 2; Line.Transparency = 1; Line.Visible = false
        table.insert(Indicator.Lines, Line)
    end
    Indicator.Update = function(self, targetPos)
        if not _G.Settings.TargetIndicator or not targetPos then
            for _,l in ipairs(self.Lines) do l.Visible=false end
            return
        end
        local camPos = Camera.CFrame.Position
        local dir = (targetPos - camPos).Unit
        local up = Vector3.new(0,1,0)
        local right = dir:Cross(up).Unit
        local size = 2.5
        local rot = os.clock() * 2
        local pts = {
            targetPos + (right*math.cos(rot) + up*math.sin(rot))*size,
            targetPos + (right*math.cos(rot+1.57) + up*math.sin(rot+1.57))*size,
            targetPos + (right*math.cos(rot+3.14) + up*math.sin(rot+3.14))*size,
            targetPos + (right*math.cos(rot+4.71) + up*math.sin(rot+4.71))*size
        }
        for i=1,4 do
            local p1, v1 = Camera:WorldToViewportPoint(pts[i])
            local p2, v2 = Camera:WorldToViewportPoint(pts[i%4+1])
            local line = self.Lines[i]
            line.Visible = v1 and v2
            if line.Visible then line.From=Vector2.new(p1.X,p1.Y); line.To=Vector2.new(p2.X,p2.Y) end
        end
    end
    Indicator.Destroy = function(self) for _,l in ipairs(self.Lines) do l:Remove() end end
    return Indicator
end
